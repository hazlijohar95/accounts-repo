{
  "name": "accounts-repo-auth-service",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx src/server.ts",
    "start": "node dist/server.js",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "auth:migrate": "better-auth migrate --config src/auth.ts",
    "auth:generate": "better-auth generate --config src/auth.ts"
  },
  "dependencies": {
    "@hono/node-server": "latest",
    "better-auth": "latest",
    "hono": "latest",
    "pg": "latest"
  },
  "devDependencies": {
    "@better-auth/cli": "^1.4.21",
    "@types/node": "latest",
    "@types/pg": "latest",
    "tsx": "latest",
    "typescript": "latest"
  }
}
