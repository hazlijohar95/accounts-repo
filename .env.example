# Copy to .env for local development, then export it in each shell before running services:
# set -a; source .env; set +a

# Postgres from docker-compose.yml.
POSTGRES_HOST_PORT=5432
DATABASE_URL=postgres://accounts_repo:accounts_repo@127.0.0.1:5432/accounts_repo

# Better Auth service.
AUTH_PORT=8081
BETTER_AUTH_SECRET=replace-with-a-32-plus-character-local-secret
BETTER_AUTH_URL=http://127.0.0.1:5173
BETTER_AUTH_TRUSTED_ORIGINS=http://127.0.0.1:5173,http://127.0.0.1:5179
AUTH_SERVICE_URL=http://127.0.0.1:8081
# Replace before starting services. Placeholder values are rejected at startup.
AUTH_INTERNAL_TOKEN=replace-with-32-plus-character-local-internal-token

# Rust API.
ACCOUNTS_REPO_BIND_ADDR=127.0.0.1:8080
CORS_ALLOWED_ORIGIN=http://127.0.0.1:5173

# Vite proxy targets.
BACKEND_URL=http://127.0.0.1:8080

# Optional local-only dev auth. Keep disabled unless you are running an explicit dev-auth flow.
# ACCOUNTS_REPO_AUTH_DISABLED_DEV=1
# VITE_DEV_AUTH_EMAIL=aina@ahadvisory.test
# VITE_DEV_AUTH_NAME='Aina Rahman'
# VITE_DEV_AUTH_ID=seed-preparer
